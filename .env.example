# =============================================================================
# Parallax secrets — EXAMPLE
# =============================================================================
# Copy to .env (gitignored) and fill in. NEVER commit the real .env.
# Only .env.example is tracked. Keep non-secret config in
# config/settings.yaml instead.
# =============================================================================

# --- LLM (Claude) ----------------------------------------------------------
# Used for summarization, steelmanning, liberty/oppression tagging, and
# adjudicating tagger disagreements.
ANTHROPIC_API_KEY=

# --- Corpus / discovery APIs ----------------------------------------------
# Media Cloud: corpus construction and attention validation. `pip install mediacloud`
MEDIACLOUD_API_KEY=
# GDELT DOC 2.0 needs no key; left here for documentation only.

# --- Datastore (only when datastore.kind = postgres) -----------------------
# PARALLAX_POSTGRES_DSN=postgresql://user:password@localhost:5432/parallax
